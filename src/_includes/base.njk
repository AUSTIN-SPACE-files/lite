<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ site.businessName }} {{ site.businessDescriptor }}{% if site.metaTitleSuffix %} | {{ site.metaTitleSuffix }}{% endif %}</title>
  <meta name="description" content="{{ site.metaDescription }}">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png">
  <style>
    :root {
      --color-primary: {{ site.colorPrimary }};
      --color-accent: {{ site.colorAccent }};
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container">
      {% include "logo.njk" %}
      <p>{{ site.phone }}</p>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container">
      {% include "logo.njk" %}
      {% include "social.njk" %}
      <p class="footer-note">&copy; {% year %} {{ site.businessName }} {{ site.businessDescriptor }} &mdash; All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
