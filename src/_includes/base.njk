{% from "brand-icon.njk" import render as brandIcon %}
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ siteName }}{% if site.metaTitleSuffix %} | {{ site.metaTitleSuffix }}{% endif %}</title>
  <meta name="description" content="{{ site.metaDescription }}">
  <link rel="stylesheet" href="/assets/css/style.css">
  {% if hasGallery %}<link rel="stylesheet" href="/assets/vendor/glightbox/glightbox.min.css">{% endif %}
  {% if hasContactForm %}<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>{% endif %}
  <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png">
  <style>
    :root {
      --color-primary: {{ site.colorPrimary }};
      --color-accent: {{ site.colorAccent }};
    }
  </style>
  {% include "schema.njk" %}
</head>
<body>
  <header class="site-header">
    <div class="container">
      {% include "logo.njk" %}
      {% include "social.njk" %}
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container footer-main">
      <div class="footer-texture" aria-hidden="true">
        {{ brandIcon("footer-watermark-icon", site.businessName) }}
      </div>
      <div class="footer-content">
        {% include "logo.njk" %}
        <p class="footer-blurb">{{ site.footerBlurb }}</p>
        {% include "social.njk" %}
      </div>
    </div>

    <div class="footer-credit-row">
      <div class="container footer-credit">
        <p class="footer-note">&copy; {% year %} {{ siteName }} &mdash; All rights reserved.</p>
        <a href="https://austinspace.co.uk" target="_blank" rel="noopener noreferrer" class="credit-logo-link">
          <span>Site by</span>
          <img src="/assets/images/AS_Logo.svg" alt="AUSTIN_SPACE" class="credit-logo" eleventy:ignore>
        </a>
      </div>
    </div>
  </footer>

  {% if hasGallery %}
  <script src="/assets/vendor/glightbox/glightbox.min.js"></script>
  <script>GLightbox({ selector: '.glightbox' });</script>
  {% endif %}
  {% if hasContactForm %}<script src="/assets/js/contact.js"></script>{% endif %}
</body>
</html>
