{# Generic SVG shell — sizing/class/viewBox only, never a mark of its own.
   The mark lives in brand-mark.njk's slot; this macro just wraps whatever
   that slot renders via {% call %}/caller(). `viewBox` defaults to Lucide's
   native 24×24 grid — a mark sourced from a different coordinate space
   (most Font Awesome icons) passes its own via brand-mark.njk's viewBox()
   macro, so the shell's own signature never has to change per client. #}
{% macro render(className, viewBox="0 0 24 24") %}<svg class="{{ className }}" xmlns="http://www.w3.org/2000/svg" viewBox="{{ viewBox }}">{{ caller() }}</svg>{% endmacro %}
