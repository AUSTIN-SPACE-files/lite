{# PER-CLIENT SLOT — the one file a re-skin edits to set the brand mark.
   Currently set to Maple & Bean's own mark: Lucide's "coffee" glyph
   (same path data as the "coffee" service icon in services.njk), native to
   a 24×24 grid, so viewBox() below just confirms the shell's default
   rather than overriding it — a Font Awesome source would instead return
   that source SVG's own viewBox value here. `name` arrives as an explicit
   parameter (unused by this glyph, kept so call sites never need to
   change) — this macro is imported without `with context`, same as
   brand-icon.njk. #}
{% macro render(name) %}<g fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="6" y1="2" y2="4"/><line x1="10" x2="10" y1="2" y2="4"/><line x1="14" x2="14" y1="2" y2="4"/></g>{% endmacro %}

{% macro viewBox() %}0 0 24 24{% endmacro %}
