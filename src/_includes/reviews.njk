<section id="reviews">
  <div class="container">
    <h2>What Neighbours Say</h2>
    <div class="reviews-grid">
      {% for review in reviews %}
      <div class="review-card">
        <p class="stars">{% for n in range(0, review.rating) %}&#9733;{% endfor %}{% for n in range(review.rating, 5) %}&#9734;{% endfor %}</p>
        <p>&ldquo;{{ review.quote }}&rdquo;</p>
        <p class="reviewer">{{ review.name }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
