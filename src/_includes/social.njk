} %}
<div class="social-row">
  {% for platform, url in social %}
    {% if socialIcons[platform] %}
    <a href="{{ url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ platform | capitalize }}">
      {{ socialIcons[platform] | safe }}
    </a>
    {% endif %}
  {% endfor %}
</div>
