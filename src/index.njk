---
layout: base.njk
hasContactForm: true
---
{% from "contact-icons.njk" import render as contactIcon %}
<section class="hero">
  <img class="hero-bg" src="/assets/images/{{ site.heroImage }}" alt="" loading="eager">
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <h1 class="logo hero-heading">
      {% include "logo-lockup.njk" %}
    </h1>
    <p>{{ site.tagline }}</p>
  </div>
</section>

<section class="contact-stats">
  <div class="container contact-stats-grid">
    <a href="tel:{{ site.phone | replace(' ', '') }}" class="stat-item">
      {{ contactIcon("phone", "stat-icon") }}
      <span class="stat-text mono-value">{{ site.phone }}</span>
    </a>
    <a href="mailto:{{ site.email }}" class="stat-item">
      {{ contactIcon("mail", "stat-icon") }}
      <span class="stat-text mono-value stat-email">{{ site.email }}</span>
    </a>
    {% if hasAddress %}
    <div class="stat-item">
      {{ contactIcon("map-pin", "stat-icon") }}
      <span class="stat-text mono-value">{{ site.streetAddress }}, {{ site.addressLocality }}, {{ site.addressCountryDisplay }}</span>
    </div>
    {% endif %}
  </div>
</section>

{% if hasServices %}{% include "services.njk" %}{% endif %}
{% if hasGallery %}{% include "gallery.njk" %}{% endif %}
{% if hasReviews %}{% include "reviews.njk" %}{% endif %}

<section class="contact-section" id="contact">
  <div class="container">
    <h2>Visit or Say Hello</h2>

    {% if hasAddress %}
    <div class="card map-card">
      <p class="section-label label-mono">Visit us</p>
      <div class="map-wrap">
        <iframe
          src="https://www.google.com/maps?q={{ (site.streetAddress ~ ', ' ~ site.addressLocality ~ ', ' ~ site.addressCountryDisplay) | urlencode }}&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Map to {{ siteName }}">
        </iframe>
      </div>
    </div>
    {% endif %}

    <div class="contact-grid">
      <div class="card contact-form-card">
        <p class="section-label label-mono">Get in touch</p>
        <form name="contact" method="POST" class="contact-form" data-worker-url="{{ site.formWorkerUrl }}">
          <p class="hp-field">
            <label>Don't fill this out if you're human: <input type="text" name="website" autocomplete="off" tabindex="-1"></label>
          </p>

          <div>
            <label for="name" class="field-label">Name</label>
            <input type="text" id="name" name="name" required>
          </div>

          <div>
            <label for="email" class="field-label">Email</label>
            <input type="email" id="email" name="email" required>
          </div>

          <div>
            <label for="message" class="field-label">Message</label>
            <textarea id="message" name="message" required></textarea>
          </div>

          <div class="cf-turnstile" data-sitekey="{{ site.turnstileSiteKey }}" data-size="flexible"></div>

          <p class="form-privacy-note">We'll only use your details to reply to you. See our <a href="#privacy" class="glightbox">Privacy Policy</a>.</p>

          <p class="form-status" role="alert"></p>

          <button type="submit">Send Message</button>
        </form>
      </div>

      <address class="card contact-info-card">
        <p class="section-label label-mono">Contact details</p>
        <ul class="contact-list">
          <li><a href="tel:{{ site.phone | replace(' ', '') }}" class="contact-list-row">{{ contactIcon("phone", "contact-icon", "2") }}<span class="mono-value">{{ site.phone }}</span></a></li>
          <li><a href="mailto:{{ site.email }}" class="contact-list-row">{{ contactIcon("mail", "contact-icon", "2") }}<span class="mono-value">{{ site.email }}</span></a></li>
          {% if hasAddress %}<li class="contact-list-row">{{ contactIcon("map-pin", "contact-icon", "2") }}<span class="mono-value">{{ site.streetAddress }}, {{ site.addressLocality }}, {{ site.addressCountryDisplay }}</span></li>{% endif %}
        </ul>

        {% if hasHours %}
        <p class="section-label label-mono" id="hours-heading">Opening hours</p>
        <table class="hours-table" aria-labelledby="hours-heading">
          <tbody>
            {% for slot in site.hours %}
            <tr>
              <th scope="row">{{ slot.day }}</th>
              <td>{% if slot.closed %}Closed{% else %}{{ slot.open }} – {{ slot.close }}{% endif %}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        {% endif %}
      </address>
    </div>
  </div>
</section>
