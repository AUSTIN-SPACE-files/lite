---
layout: base.njk
---
{% from "contact-icons.njk" import render as contactIcon %}
<section class="hero">
  <img class="hero-bg" src="/assets/images/{{ site.heroImage }}" alt="" loading="eager">
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <h1 class="logo hero-heading">
      {% include "logo-lockup.njk" %}
    </h1>
    <p>{{ site.tagline }}</p>
  </div>
</section>

<section class="contact-stats">
  <div class="container contact-stats-grid">
    <a href="tel:{{ site.phone | replace(' ', '') }}" class="stat-item">
      {{ contactIcon("phone", "stat-icon") }}
      <span class="stat-text label-mono">{{ site.phone }}</span>
    </a>
    <a href="mailto:{{ site.email }}" class="stat-item">
      {{ contactIcon("mail", "stat-icon") }}
      <span class="stat-text label-mono stat-email">{{ site.email }}</span>
    </a>
    <div class="stat-item">
      {{ contactIcon("map-pin", "stat-icon") }}
      <span class="stat-text label-mono">{{ site.address }}</span>
    </div>
  </div>
</section>

{% include "services.njk" %}
{% include "gallery.njk" %}
{% include "reviews.njk" %}

<section class="contact-section" id="contact">
  <div class="container">
    <h2>Visit or Say Hello</h2>

    <div class="card map-card">
      <p class="section-label label-mono">Visit us</p>
      <div class="map-wrap">
        <iframe
          src="https://www.google.com/maps?q={{ site.address | urlencode }}&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Map to {{ site.businessName }} {{ site.businessDescriptor }}">
        </iframe>
      </div>
    </div>

    <div class="contact-grid">
      <address class="card contact-info-card">
        <p class="section-label label-mono">Contact details</p>
        <ul class="contact-list">
          <li><a href="tel:{{ site.phone | replace(' ', '') }}" class="contact-list-row">{{ contactIcon("phone", "contact-icon", "2.5") }}<span>{{ site.phone }}</span></a></li>
          <li><a href="mailto:{{ site.email }}" class="contact-list-row">{{ contactIcon("mail", "contact-icon", "2.5") }}<span>{{ site.email }}</span></a></li>
          <li class="contact-list-row">{{ contactIcon("map-pin", "contact-icon", "2.5") }}<span>{{ site.address }}</span></li>
        </ul>

        <p class="section-label label-mono">Opening hours</p>
        <dl class="hours-list">
          {% for slot in site.hours %}
          <div class="hours-row">
            <dt>{{ slot.day }}</dt>
            <dd>{{ slot.time }}</dd>
          </div>
          {% endfor %}
        </dl>
      </address>

      <div class="card contact-form-card">
        <p class="section-label label-mono">Get in touch</p>
        <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="contact-form">
          <input type="hidden" name="form-name" value="contact">
          <p class="hp-field">
            <label>Don't fill this out if you're human: <input name="bot-field"></label>
          </p>

          <div>
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required>
          </div>

          <div>
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
          </div>

          <div>
            <label for="message">Message</label>
            <textarea id="message" name="message" required></textarea>
          </div>

          <button type="submit">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>
